{
  "name": "amex-cli",
  "version": "0.1.0",
  "description": "CLI for syncing and querying Amex card data, benefits, and offers.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "amex": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run check && npm run build",
    "start": "node --import tsx ./src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kevchentw/amex-cli"
  },
  "homepage": "https://github.com/kevchentw/amex-cli#readme",
  "bugs": {
    "url": "https://github.com/kevchentw/amex-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "keytar": "^7.9.0",
    "patchright": "^1.57.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
